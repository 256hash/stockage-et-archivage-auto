#!/bin/bash

# --- 1. Variables de configuration ---
DATE_FORMAT=$(date +%d-%m-%Y_%H:%M:%S)
BASE_DIR="/home/user/owncloud-data" # À adapter selon votre installation
SOURCE_DIR="$BASE_DIR/toip"
DEST_DIR="$BASE_DIR/archive"
LOG_NAME="sio2-$DATE_FORMAT"

# Coordonnées du serveur FTP (OMV site principal)
FTP_HOST="192.168.20.33"  # IP de votre VM OMV
FTP_USER="admin_toip"
FTP_PASS="sio%2025"
REMOTE_DIR="archives_toip"

# --- 2. Sauvegarde locale du CSV ---
# On copie le fichier source vers l'archive avec le nouveau nom
cp $SOURCE_DIR/*.csv $DEST_DIR/$LOG_NAME.csv

# --- 3. Compression du répertoire TOIP ---
# On compresse le contenu en un fichier .zip
zip -j $DEST_DIR/$LOG_NAME.zip $SOURCE_DIR/*.csv

# --- 4. Transfert FTP vers le site principal ---
# Utilisation de la commande curl (souvent installée par défaut et robuste)
curl --ftp-create-dirs -T "$DEST_DIR/$LOG_NAME.zip" \
     ftp://$FTP_HOST/$REMOTE_DIR/ \
     --user $FTP_USER:$FTP_PASS

echo "Opération terminée avec succès le $DATE_FORMAT"


